# -*- coding: utf-8 -*-
"""PlantDiseaseDataset.ipynb

Automatically generated by Colab.

Original file is located at
    https://colab.research.google.com/drive/1zdBonm-eBaONQHRN9rsf1BRfe_b7RK-i
"""

import os
import shutil
import time
import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers, mixed_precision


# Dataset paths
drive_path = "/content/drive/MyDrive/PlantVillage/PlantVillage"
local_path = "/content/PlantVillage_Clean"

# Copy dataset from Google Drive to Colab local storage if not already copied
if os.path.exists(local_path):
    print("Clean local dataset already exists.")
else:
    if os.path.exists(drive_path):
        print("Copying correct dataset from Drive to Colab local storage...")
        shutil.copytree(drive_path, local_path)
        print("Copy completed.")
    else:
        raise FileNotFoundError(
            "Correct PlantVillage folder not found at: "
            "/content/drive/MyDrive/PlantVillage/PlantVillage"
        )

data_dir = local_path
print("Using dataset:", data_dir)


# Basic training settings
IMG_SIZE = (128, 128)
BATCH_SIZE = 32
SEED = 123

EPOCHS_TOP = 10
EPOCHS_FINE = 5

DO_FINE_TUNING = True

STEPS_PER_EPOCH = 300
VALIDATION_STEPS = 80

# Mixed precision helps speed up training on supported GPUs
mixed_precision.set_global_policy("mixed_float16")

print("\nTraining Configuration")
print("Image size:", IMG_SIZE)
print("Batch size:", BATCH_SIZE)
print("Top training epochs:", EPOCHS_TOP)
print("Fine-tuning epochs:", EPOCHS_FINE)
print("Steps per epoch:", STEPS_PER_EPOCH)
print("Validation steps:", VALIDATION_STEPS)
print("GPU Available:", tf.config.list_physical_devices("GPU"))


# Check folders detected as classes
print("\nDetected folders/classes:")
for item in sorted(os.listdir(data_dir)):
    folder_path = os.path.join(data_dir, item)

    if os.path.isdir(folder_path):
        print("-", item)


# Load training dataset
train_ds_raw = keras.utils.image_dataset_from_directory(
    data_dir,
    validation_split=0.2,
    subset="training",
    seed=SEED,
    image_size=IMG_SIZE,
    batch_size=BATCH_SIZE
)

# Load validation dataset
val_ds_raw = keras.utils.image_dataset_from_directory(
    data_dir,
    validation_split=0.2,
    subset="validation",
    seed=SEED,
    image_size=IMG_SIZE,
    batch_size=BATCH_SIZE
)

class_names = train_ds_raw.class_names
num_classes = len(class_names)

print(f"\nFound {num_classes} classes:")
print(class_names)

# This check prevents using the wrong parent folder as dataset path
if "PlantVillage" in class_names:
    raise ValueError(
        "Wrong dataset path. 'PlantVillage' is still being detected as a class."
    )

# The current dataset should contain exactly 15 classes
if num_classes != 15:
    raise ValueError(
        f"Expected 15 classes, but found {num_classes}. Please check dataset folders."
    )


AUTOTUNE = tf.data.AUTOTUNE

# Prepare dataset pipeline for faster training
train_ds = train_ds_raw.shuffle(1000).cache().repeat().prefetch(AUTOTUNE)
val_ds = val_ds_raw.cache().repeat().prefetch(AUTOTUNE)


# Data augmentation for better generalization
data_augmentation = keras.Sequential(
    [
        layers.RandomFlip("horizontal"),
        layers.RandomRotation(0.10),
        layers.RandomZoom(0.10),
        layers.RandomContrast(0.10)
    ],
    name="data_augmentation"
)


# Load EfficientNetV2B0 without its original classification layer
base_model = tf.keras.applications.EfficientNetV2B0(
    include_top=False,
    weights="imagenet",
    input_shape=IMG_SIZE + (3,)
)

# First train only the custom classifier layers
base_model.trainable = False

inputs = keras.Input(shape=IMG_SIZE + (3,), name="input_layer")

x = data_augmentation(inputs)
x = tf.keras.applications.efficientnet_v2.preprocess_input(x)
x = base_model(x, training=False)

x = layers.GlobalAveragePooling2D(name="global_average_pooling")(x)

# Custom classification head
x = layers.Dense(256, activation="relu", name="dense_head_1")(x)
x = layers.Dropout(0.35, name="dropout_1")(x)

x = layers.Dense(128, activation="relu", name="dense_head_2")(x)
x = layers.Dropout(0.25, name="dropout_2")(x)

outputs = layers.Dense(
    num_classes,
    activation="softmax",
    dtype="float32",
    name="classification_output"
)(x)

model = keras.Model(
    inputs,
    outputs,
    name="plant_village_efficientnet_final"
)


# Compile model for initial training
model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=1e-4),
    loss=keras.losses.SparseCategoricalCrossentropy(),
    metrics=["accuracy"]
)

model.summary()


# Paths for saving trained models
checkpoint_dir = "/content/drive/MyDrive/PlantVillage_Checkpoints"
os.makedirs(checkpoint_dir, exist_ok=True)

best_top_model_path = os.path.join(
    checkpoint_dir,
    "best_top_efficientnet_model.keras"
)

best_finetuned_model_path = os.path.join(
    checkpoint_dir,
    "best_finetuned_efficientnet_model.keras"
)

final_model_path = os.path.join(
    checkpoint_dir,
    "final_best_efficientnet_model.keras"
)


# Callbacks used during first training stage
top_callbacks = [
    keras.callbacks.ModelCheckpoint(
        filepath=best_top_model_path,
        monitor="val_accuracy",
        save_best_only=True,
        verbose=1
    ),
    keras.callbacks.EarlyStopping(
        monitor="val_accuracy",
        patience=4,
        restore_best_weights=True,
        verbose=1
    ),
    keras.callbacks.ReduceLROnPlateau(
        monitor="val_loss",
        factor=0.3,
        patience=2,
        min_lr=1e-7,
        verbose=1
    )
]


# Stage 1: train the classifier head
print("\nStage 1: Training classifier head...")

start_time = time.time()

history_top = model.fit(
    train_ds,
    validation_data=val_ds,
    epochs=EPOCHS_TOP,
    steps_per_epoch=STEPS_PER_EPOCH,
    validation_steps=VALIDATION_STEPS,
    callbacks=top_callbacks
)


# Stage 2: fine-tune selected EfficientNet layers
if DO_FINE_TUNING:
    print("\nStage 2: Fine-tuning last EfficientNet layers...")

    base_model.trainable = True

    # Keep most of the base model frozen and train only the last 30 layers
    for layer in base_model.layers[:-30]:
        layer.trainable = False

    # BatchNormalization layers are kept frozen for stable fine-tuning
    for layer in base_model.layers:
        if isinstance(layer, layers.BatchNormalization):
            layer.trainable = False

    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=1e-5),
        loss=keras.losses.SparseCategoricalCrossentropy(),
        metrics=["accuracy"]
    )

    fine_callbacks = [
        keras.callbacks.ModelCheckpoint(
            filepath=best_finetuned_model_path,
            monitor="val_accuracy",
            save_best_only=True,
            verbose=1
        ),
        keras.callbacks.EarlyStopping(
            monitor="val_accuracy",
            patience=3,
            restore_best_weights=True,
            verbose=1
        ),
        keras.callbacks.ReduceLROnPlateau(
            monitor="val_loss",
            factor=0.3,
            patience=2,
            min_lr=1e-7,
            verbose=1
        )
    ]

    history_fine = model.fit(
        train_ds,
        validation_data=val_ds,
        epochs=EPOCHS_FINE,
        steps_per_epoch=STEPS_PER_EPOCH,
        validation_steps=VALIDATION_STEPS,
        callbacks=fine_callbacks
    )


# Final validation check
print("\nEvaluating final model...")

final_loss, final_accuracy = model.evaluate(
    val_ds,
    steps=VALIDATION_STEPS
)

print(f"\nFinal validation accuracy: {final_accuracy * 100:.2f}%")
print(f"Final validation loss: {final_loss:.4f}")


# Save final trained model
model.save(final_model_path)

end_time = time.time()
total_minutes = (end_time - start_time) / 60

print("\nTraining complete.")
print(f"Best top model saved to: {best_top_model_path}")
print(f"Best fine-tuned model saved to: {best_finetuned_model_path}")
print(f"Final model saved to: {final_model_path}")
print(f"Total training time: {total_minutes:.2f} minutes")